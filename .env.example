# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# Claude API Configuration
ANTHROPIC_API_KEY=your_claude_api_key_here

# Application Configuration
VAULT_PATH=./vault
# Batch mode queues messages in database for batch processing
# Set to true to enable batch mode (requires DATABASE_ENABLED=true)
BATCH_MODE=false
# Interval in minutes for continuous batch processing (default: 60)
BATCH_INTERVAL_MINUTES=60
# Maximum number of messages to process per batch run (default: 100)
# Lower this if processing takes too long or you want more frequent processing
BATCH_PROCESS_LIMIT=100
WEBHOOK_PORT=8080
WEBHOOK_HOST=0.0.0.0

# Note Categories (comma-separated, strictly enforced)
# Customize this list to match your needs
PREDEFINED_CATEGORIES=Sayings,Poetry,Jots,History,Strategy,Concepts,Path

# Git Auto-Sync Configuration (for Obsidian sync)
# Set GIT_AUTO_COMMIT=true to enable automatic Git commits after creating notes
GIT_AUTO_COMMIT=false
GIT_AUTO_PUSH=false
GIT_REMOTE_NAME=origin
GIT_BRANCH_NAME=main
GIT_COMMIT_MESSAGE_TEMPLATE=Add note: {title}

# Vault Repository URL (for cloud deployments)
# If set, the vault will be cloned from this repository on first startup
# Format: https://YOUR_GITHUB_TOKEN@github.com/yourusername/obsidian-vault.git
# Leave empty for local development
VAULT_REPO_URL=

# HTTP API Configuration (optional)
# Enable HTTP API for programmatic note creation
HTTP_API_ENABLED=false
HTTP_API_KEY=your_secret_api_key_here

# Dashboard Configuration (optional)
# Web-based dashboard for monitoring and analytics
DASHBOARD_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_secure_password

# YouTube Transcription Configuration (optional)
# Enable YouTube video transcription and note creation
YOUTUBE_ENABLED=false
# Preferred transcript languages (comma-separated)
YOUTUBE_TRANSCRIPT_LANGUAGES=en,ar
# Threshold for summarizing long transcripts (in characters)
YOUTUBE_SUMMARIZE_THRESHOLD=10000
# Chunk size for processing long transcripts (in characters)
YOUTUBE_CHUNK_SIZE=4000

# OpenAI API Configuration (Required for YouTube Transcription)
# Used for Whisper API to transcribe videos without captions
# Sign up at: https://platform.openai.com/
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
# REQUIRED for batch mode and message replay functionality
DATABASE_ENABLED=true
# Database URL - supports SQLite and PostgreSQL
# SQLite (local): sqlite+aiosqlite:///./notes.db
# PostgreSQL (production/Railway): postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./notes.db
# Enable SQL query logging (useful for debugging)
DATABASE_ECHO=false
# Maximum number of retry attempts for failed messages
DATABASE_MAX_RETRY_COUNT=3
# Note: Batch mode uses database queue (queued_messages table)
# No JSON files are created in queue/ folder anymore
